<button
  data-menu-toggle
  class="fixed h-28 top-1/2 -mt-14 right-24 max-md:h-20 max-md:-mt-10 max-md:right-12 z-50 flex items-center justify-center"
>
  <img src="/assets/svgs/Menu_icon.svg" class="w-full h-full" />
</button>

<div
  id="overlay"
  class="fixed inset-0 bg-black/10 opacity-0 pointer-events-none transition-opacity duration-300 z-40"
></div>

<aside
  id="sidebar"
  class="fixed top-0 right-0 h-screen w-full max-w-[550px] bg-primary z-50 translate-x-full transition-transform duration-300 ease-in-out flex flex-col justify-center"
>
  <button
    data-menu-toggle
    class="fixed h-28 top-1/2 -mt-14 right-24 max-md:h-20 max-md:-mt-10 max-md:right-12 z-50 flex items-center justify-center"
  >
    <img src="/assets/svgs/Menu_back.svg" class="w-full h-full" />
  </button>

  <div class="flex flex-col gap-16 px-16">
    <img
      class="w-[250px]"
      src="/assets/svgs/Logo.svg"
      alt="KH - kosmetické studio"
      width="420"
      height="210"
      loading="lazy"
      decoding="async"
      aria-hidden="true"
      draggable="false"
    />

    <nav>
      <ul class="flex flex-col text-3xl italic">
        <li><a href="{% if page.url != '/' %}/{% endif %}#uvod">úvod</a></li>
        <li><a href="{% if page.url != '/' %}/{% endif %}#o-mne">o mně</a></li>
        <li><a href="/sluzby">služby</a></li>
        <li><a href="/salon">salon</a></li>
        <li><a href="#kontakt"> kontakt </a></li>
        <li class="pt-16">
          <a href="/uvolnene-terminy">uvolněné<br />termíny</a>
        </li>
      </ul>
    </nav>
  </div>

  <div class="bg-black text-white absolute bottom-0 left:0 w-full">
    <div class="flex items-center m-auto container px-8">
      <div class="flex-auto md:text-base py-3 text-xs">
        <img
          alt="copyright icon"
          class="inline-block mr-4"
          src="/assets/svgs/copyright-light.svg"
          decoding="async"
          loading="eager"
          height="20"
          width="20"
        />
        tvoříme weby s radostí
      </div>
      <div class="py-3 flex-right">
        <a href="https://matfix.cz" target="_blank" title="Matfix"
          ><img
            alt="matfix icon"
            class="inline-block"
            src="/assets/svgs/matfix_test_black.svg"
            decoding="async"
            loading="eager"
            height="15"
            width="58" /></a
        ><img
          alt="footer icon"
          class="inline-block"
          src="/assets/svgs/tvorba_paticka.svg"
          decoding="async"
          loading="eager"
          height="20"
          width="20"
        />
      </div>
    </div>
  </div>
</aside>
